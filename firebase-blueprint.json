{
  "entities": {
    "MediaAsset": {
      "title": "Media Asset",
      "description": "Metadata for a media file indexed in the library",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "audio", "image"] },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "thumbnail": { "type": "string", "description": "Base64 or path to thumb" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "path", "type"]
    }
  }
}
